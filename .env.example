# ─────────────────────────────────────────────────────────────────────────────
# SafeGaze — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Twilio (SMS Alerts) — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_twilio_api_secret
TWILIO_FROM=+1XXXXXXXXXX
GUARDIAN_PHONE=+91XXXXXXXXXX

# Email (SMTP) — Use a Gmail App Password, NOT your real password
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_SENDER=your@gmail.com
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
GUARDIAN_EMAIL=guardian@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Fall Detection Tuning
FALL_ANGLE_THRESHOLD=45
FALL_TIME_THRESHOLD=1.5
COOLDOWN_PERIOD=30
MODEL_PATH=yolov8n-pose.pt

# Web Login Credentials — change these before deploying!
LOGIN_USERNAME=admin
LOGIN_PASSWORD=change_me_to_something_strong

# Session Secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_64_char_random_hex_string_here

# Gemini AI Chatbot (optional, get a free key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
